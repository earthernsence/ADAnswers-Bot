{
  "compilerOptions": {
    // Enable latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // We now have to explicitly declare types here in compilerOptions
    // on TypeScript versions 6 and 7. This is because they no longer
    // auto-discover @types packages. Therefore, any time an additional
    // @types package is added (which still needs to be installed in the
    // usual way, since it needs to be in node_modules), add another
    // entry to this array.
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Path aliases
    "paths": {
      "@/types/*": ["./types/*"],
      "@/images/*": ["./images/*"],
      "@/utils/*": ["./utils/*"]
    }
  }
}
